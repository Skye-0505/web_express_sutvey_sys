<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= config.PAGE_TITLE %>
    </title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <!-- Custom CSS -->
    <link rel='stylesheet' href='/stylesheets/style.css' />
</head>

<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="fas fa-heartbeat me-2"></i>
                <%= config.NAV_BRAND %>
            </a>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container my-5">
        <!-- Page Header -->
        <div class="text-center mb-5">
            <h1 class="display-4 fw-bold text-primary">
                <i class="fas fa-clipboard-list me-3"></i>
                <%= config.PAGE_HEADING %>
            </h1>
            <p class="lead text-muted">
                <%= config.PAGE_SUBTITLE %>
            </p>
            <hr class="my-4 w-25 mx-auto">
        </div>

        <!-- Progress Bar -->
        <div class="progress mb-4" style="height: 30px;">
            <div class="progress-bar progress-bar-striped progress-bar-animated bg-success" role="progressbar"
                style="width: 0%" id="formProgress">
                0<%= config.PROGRESS_COMPLETE %>
            </div>
        </div>

        <!-- Form -->
        <form action="/submit" method="POST" id="surveyForm" class="needs-validation" novalidate>
            <!-- Part 1: Basic Information -->
            <div class="card mb-4 shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h3 class="h5 mb-0">
                        <i class="fas fa-user-circle me-2"></i>
                        <%= config.SECTIONS.BASIC_INFO %>
                    </h3>
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <!-- Age Group -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-birthday-cake me-2 text-primary"></i>
                                <%= config.LABELS.age_group %> <span class="text-danger">*</span>
                            </label>
                            <select name="age_group" class="form-select form-select-lg" required>
                                <option value="" selected disabled>
                                    <%= config.LABELS.select_age %>
                                </option>
                                <% Object.entries(config.AGE_GROUPS).forEach(([value, label])=> { %>
                                    <option value="<%= value %>">
                                        <%= label %>
                                    </option>
                                    <% }); %>
                            </select>
                            <div class="invalid-feedback">
                                <%= config.LABELS.validation.select_age %>
                            </div>
                        </div>

                        <!-- Gender -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold d-block">
                                <i class="fas fa-venus-mars me-2 text-primary"></i>
                                <%= config.LABELS.gender %> <span class="text-danger">*</span>
                            </label>
                            <div class="btn-group w-100" role="group">
                                <% Object.entries(config.GENDERS).forEach(([value, data])=> { %>
                                    <input type="radio" class="btn-check" name="gender" id="gender<%= value %>"
                                        value="<%= value %>" required>
                                    <label class="btn btn-outline-primary" for="gender<%= value %>">
                                        <i class="fas fa-<%= data.icon %> me-2"></i>
                                        <%= data.label %>
                                    </label>
                                    <% }); %>
                            </div>
                            <div class="invalid-feedback">
                                <%= config.LABELS.validation.select_gender %>
                            </div>
                        </div>

                        <!-- District -->
                        <div class="col-md-12 mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-map-marker-alt me-2 text-primary"></i>
                                <%= config.LABELS.district %> <span class="text-danger">*</span>
                            </label>
                            <select name="district" class="form-select form-select-lg" required>
                                <option value="" selected disabled>
                                    <%= config.LABELS.select_district %>
                                </option>
                                <% Object.entries(config.DISTRICTS).forEach(([region, districts])=> { %>
                                    <optgroup label="<%= region %>">
                                        <% districts.forEach(district=> { %>
                                            <option value="<%= district %>">
                                                <%= district %>
                                            </option>
                                            <% }); %>
                                    </optgroup>
                                    <% }); %>
                            </select>
                            <div class="invalid-feedback">
                                <%= config.LABELS.validation.select_district %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Part 2: Exercise Habits -->
            <div class="card mb-4 shadow-sm border-0">
                <div class="card-header bg-success text-white py-3">
                    <h3 class="h5 mb-0">
                        <i class="fas fa-running me-2"></i>
                        <%= config.SECTIONS.EXERCISE %>
                    </h3>
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <!-- Exercise Frequency -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-calendar-check me-2 text-success"></i>
                                <%= config.LABELS.exercise_frequency %> <span class="text-danger">*</span>
                            </label>
                            <select name="exercise_frequency" class="form-select" required>
                                <option value="" selected disabled>
                                    <%= config.LABELS.select_exercise_frequency %>
                                </option>
                                <% Object.entries(config.EXERCISE_FREQUENCY).forEach(([value, label])=> { %>
                                    <option value="<%= value %>">
                                        <%= label %>
                                    </option>
                                    <% }); %>
                            </select>
                            <div class="invalid-feedback">
                                <%= config.LABELS.validation.select_exercise_frequency %>
                            </div>
                        </div>

                        <!-- Exercise Type -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold d-block">
                                <i class="fas fa-dumbbell me-2 text-success"></i>
                                <%= config.LABELS.exercise_type %>
                            </label>
                            <div class="row">
                                <% const midPoint=Math.ceil(config.EXERCISE_TYPES.length / 2); const
                                    firstHalf=config.EXERCISE_TYPES.slice(0, midPoint); const
                                    secondHalf=config.EXERCISE_TYPES.slice(midPoint); %>
                                    <div class="col-6">
                                        <% firstHalf.forEach(type=> { %>
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" name="exercise_type"
                                                    value="<%= type.value %>" id="ex<%= type.value %>">
                                                <label class="form-check-label" for="ex<%= type.value %>">
                                                    <i class="fas fa-<%= type.icon %> me-1"></i>
                                                    <%= type.label %>
                                                </label>
                                            </div>
                                            <% }); %>
                                    </div>
                                    <div class="col-6">
                                        <% secondHalf.forEach(type=> { %>
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" name="exercise_type"
                                                    value="<%= type.value %>" id="ex<%= type.value %>">
                                                <label class="form-check-label" for="ex<%= type.value %>">
                                                    <i class="fas fa-<%= type.icon %> me-1"></i>
                                                    <%= type.label %>
                                                </label>
                                            </div>
                                            <% }); %>
                                    </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Part 3: Sleep Habits -->
            <div class="card mb-4 shadow-sm border-0">
                <div class="card-header bg-info text-white py-3">
                    <h3 class="h5 mb-0">
                        <i class="fas fa-moon me-2"></i>
                        <%= config.SECTIONS.SLEEP %>
                    </h3>
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <!-- Sleep Hours -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-clock me-2 text-info"></i>
                                <%= config.LABELS.sleep_hours %> <span class="text-danger">*</span>
                            </label>
                            <select name="sleep_hours" class="form-select" required>
                                <option value="" selected disabled>
                                    <%= config.LABELS.select_sleep_hours %>
                                </option>
                                <% Object.entries(config.SLEEP_HOURS).forEach(([value, label])=> { %>
                                    <option value="<%= value %>">
                                        <%= label %>
                                    </option>
                                    <% }); %>
                            </select>
                            <div class="invalid-feedback">
                                <%= config.LABELS.validation.select_sleep_hours %>
                            </div>
                        </div>

                        <!-- Sleep Quality -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-star me-2 text-info"></i>
                                <%= config.LABELS.sleep_quality %> <span class="text-danger">*</span>
                            </label>
                            <select name="sleep_quality" class="form-select" required>
                                <option value="" selected disabled>
                                    <%= config.LABELS.select_sleep_quality %>
                                </option>
                                <% Object.entries(config.SLEEP_QUALITY).forEach(([value, label])=> { %>
                                    <option value="<%= value %>">
                                        <%= label %>
                                    </option>
                                    <% }); %>
                            </select>
                            <div class="invalid-feedback">
                                <%= config.LABELS.validation.select_sleep_quality %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Part 4: Dietary Habits -->
            <div class="card mb-4 shadow-sm border-0">
                <div class="card-header bg-warning text-white py-3">
                    <h3 class="h5 mb-0">
                        <i class="fas fa-utensils me-2"></i>
                        <%= config.SECTIONS.DIET %>
                    </h3>
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <!-- Diet Type -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-leaf me-2 text-warning"></i>
                                <%= config.LABELS.diet_type %> <span class="text-danger">*</span>
                            </label>
                            <select name="diet_type" class="form-select" required>
                                <option value="" selected disabled>
                                    <%= config.LABELS.select_diet_type %>
                                </option>
                                <% Object.entries(config.DIET_TYPES).forEach(([value, label])=> { %>
                                    <option value="<%= value %>">
                                        <%= label %>
                                    </option>
                                    <% }); %>
                            </select>
                            <div class="invalid-feedback">
                                <%= config.LABELS.validation.select_diet_type %>
                            </div>
                        </div>

                        <!-- Water Intake -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-tint me-2 text-warning"></i>
                                <%= config.LABELS.water_intake %> <span class="text-danger">*</span>
                            </label>
                            <input type="number" name="water_intake" class="form-control" min="1" max="15" value="6"
                                required>
                            <div class="form-text">
                                <%= config.LABELS.water_helper %>
                            </div>
                            <div class="invalid-feedback">
                                <%= config.LABELS.validation.water_range %>
                            </div>
                        </div>

                        <!-- Fast Food Frequency -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-hamburger me-2 text-warning"></i>
                                <%= config.LABELS.fastfood_frequency %> <span class="text-danger">*</span>
                            </label>
                            <select name="fastfood_frequency" class="form-select" required>
                                <option value="" selected disabled>
                                    <%= config.LABELS.select_fastfood_frequency %>
                                </option>
                                <% Object.entries(config.FASTFOOD_FREQUENCY).forEach(([value, label])=> { %>
                                    <option value="<%= value %>">
                                        <%= label %>
                                    </option>
                                    <% }); %>
                            </select>
                            <div class="invalid-feedback">
                                <%= config.LABELS.validation.select_fastfood_frequency %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Part 5: Health Self-Assessment -->
            <div class="card mb-4 shadow-sm border-0">
                <div class="card-header bg-danger text-white py-3">
                    <h3 class="h5 mb-0">
                        <i class="fas fa-heart me-2"></i>
                        <%= config.SECTIONS.SELF_ASSESSMENT %>
                    </h3>
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <!-- Health Score -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold d-block">
                                <i class="fas fa-chart-line me-2 text-danger"></i>
                                <%= config.LABELS.health_score %> <span class="text-danger">*</span>
                            </label>
                            <div class="rating-container text-center">
                                <div class="btn-group" role="group">
                                    <% config.HEALTH_SCORES.forEach(score=> { %>
                                        <input type="radio" class="btn-check" name="health_score"
                                            id="score<%= score.value %>" value="<%= score.value %>" required>
                                        <label class="btn btn-outline-danger" for="score<%= score.value %>">
                                            <%= score.label %>
                                        </label>
                                        <% }); %>
                                </div>
                            </div>
                            <div class="invalid-feedback">
                                <%= config.LABELS.validation.select_health_score %>
                            </div>
                        </div>

                        <!-- Regular Checkup -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold d-block">
                                <i class="fas fa-hospital me-2 text-danger"></i>
                                <%= config.LABELS.regular_checkup %> <span class="text-danger">*</span>
                            </label>
                            <div class="btn-group w-100" role="group">
                                <% Object.entries(config.REGULAR_CHECKUP).forEach(([value, data])=> { %>
                                    <input type="radio" class="btn-check" name="regular_checkup"
                                        id="checkup<%= value %>" value="<%= value %>" required>
                                    <label class="btn btn-outline-danger" for="checkup<%= value %>">
                                        <i class="fas fa-<%= data.icon %> me-2"></i>
                                        <%= data.label %>
                                    </label>
                                    <% }); %>
                            </div>
                            <div class="invalid-feedback">
                                <%= config.LABELS.validation.select_checkup %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Submit Buttons -->
            <div class="text-center mt-5">
                <div class="d-flex flex-column flex-sm-row justify-content-center gap-2 gap-sm-3">
                    <button type="submit" class="btn btn-primary flex-fill flex-sm-grow-0 px-sm-5 py-3">
                        <i class="fas fa-paper-plane me-2"></i>
                        <%= config.BUTTONS.submit %>
                    </button>
                    <button type="reset" class="btn btn-outline-secondary flex-fill flex-sm-grow-0 px-sm-5 py-3">
                        <i class="fas fa-undo me-2"></i>
                        <%= config.BUTTONS.reset %>
                    </button>
                </div>
            </div>
        </form>
    </div>

    <!-- Footer -->
    <footer class="bg-light py-4 mt-5">
        <div class="container text-center">
            <p class="text-muted mb-0">
                <i class="fas fa-heart text-danger me-2"></i>
                <%= config.FOOTER.text %>
            </p>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            'use strict';
            const forms = document.querySelectorAll('.needs-validation');
            Array.from(forms).forEach(form => {
                form.addEventListener('submit',event => {
                    if (!form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                    const formData = new FormData(form);
                    const formValues = {};
                    for (const [key,value] of formData.entries()) {
                        if (formValues[key]) {
                            formValues[key] = Array.isArray(formValues[key])
                                ? [...formValues[key],value]
                                : [formValues[key],value];
                        } else {
                            formValues[key] = value;
                        }
                    }
                    console.log(formData,formValues)
                    form.classList.add('was-validated');
                },false);
            });
        })();

        document.getElementById('surveyForm').addEventListener('input',function () {
            const allInputs = this.querySelectorAll('input, select');
            let filled = 0;
            let total = 0;

            allInputs.forEach(input => {
                if (input.hasAttribute('required')) {
                    total++;
                    if (input.type === 'radio') {
                        const radios = document.getElementsByName(input.name);
                        const checked = Array.from(radios).some(r => r.checked);
                        if (checked && !input.dataset.counted) {
                            filled++;
                            input.dataset.counted = 'true';
                        }
                    } else if (input.value && input.value.trim() !== '') {
                        filled++;
                    }
                }
            });

            document.querySelectorAll('input[type="radio"]').forEach(r => delete r.dataset.counted);

            const percentage = total ? Math.round((filled / total) * 100) : 0;

            const progressBar = document.getElementById('formProgress');
            progressBar.style.width = percentage + '%';
            progressBar.textContent = percentage + '% complete';
        });

        document.getElementById('surveyForm').addEventListener('reset',function () {
            setTimeout(() => {
                const progressBar = document.getElementById('formProgress');
                progressBar.style.width = '0%';
                progressBar.textContent = '0% complete';
            },10);
        });
    </script>
</body>

</html>