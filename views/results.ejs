<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thank You - Health & Lifestyle Survey</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <!-- Custom CSS -->
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <link rel='stylesheet' href='/stylesheets/results.css' />
</head>

<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="fas fa-heartbeat me-2"></i>
                <%= config.NAV_BRAND %>
            </a>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container my-5">
        <!-- Success Message -->
        <div class="text-center mb-5 success-animation">
            <div class="checkmark-circle">
                <i class="fas fa-check"></i>
            </div>
            <h1 class="display-4 fw-bold text-primary mb-3">Thank You!</h1>
            <p class="lead text-muted mb-2">Your response has been recorded successfully.</p>
            <p class="text-muted">Your contribution helps us understand health and lifestyle patterns better.</p>

            <!-- Stats Badge - 使用 db.totalCount -->
            <div class="badge-counter d-inline-flex align-items-center gap-2 mt-3">
                <i class="fas fa-users text-primary"></i>
                <span>Total Responses: <strong>
                        <%= db.totalCount.toLocaleString() %>
                    </strong></span>
            </div>
        </div>

        <!-- What's Next Section -->
        <div class="row mb-4">
            <div class="col-12">
                <h2 class="text-center mb-4">
                    <i class="fas fa-chart-line me-2 text-primary"></i>
                    Explore the Results
                </h2>
                <p class="text-center text-muted mb-5">
                    Click on any chart below to see how your responses compare with others!
                </p>
            </div>
        </div>

        <!-- Chart Cards -->
        <div class="row g-4">
            <!-- Chart 1: Bar Chart -->
            <div class="col-md-4">
                <a href="/chart/bar" class="text-decoration-none">
                    <div class="card chart-card shadow-sm h-100">
                        <div class="card-img-top">
                            <i class="fas fa-chart-bar"></i>
                        </div>
                        <div class="card-body text-center">
                            <h5 class="card-title fw-bold">Exercise & Health</h5>
                            <p class="card-text text-muted">
                                See how exercise frequency affects health scores across different age groups.
                            </p>
                            <div class="mt-3">
                                <span class="badge bg-primary me-2">Bar Chart</span>
                                <span class="badge bg-success">Interactive</span>
                            </div>
                            <button class="btn btn-outline-primary mt-3 px-4">
                                View Chart <i class="fas fa-arrow-right ms-2"></i>
                            </button>
                        </div>
                    </div>
                </a>
            </div>

            <!-- Chart 2: Pie Chart -->
            <div class="col-md-4">
                <a href="/chart/pie" class="text-decoration-none">
                    <div class="card chart-card shadow-sm h-100">
                        <div class="card-img-top">
                            <i class="fas fa-chart-pie"></i>
                        </div>
                        <div class="card-body text-center">
                            <h5 class="card-title fw-bold">Dietary Patterns</h5>
                            <p class="card-text text-muted">
                                Discover the distribution of different dietary preferences among participants.
                            </p>
                            <div class="mt-3">
                                <span class="badge bg-primary me-2">Pie Chart</span>
                                <span class="badge bg-success">Interactive</span>
                            </div>
                            <button class="btn btn-outline-primary mt-3 px-4">
                                View Chart <i class="fas fa-arrow-right ms-2"></i>
                            </button>
                        </div>
                    </div>
                </a>
            </div>

            <!-- Chart 3: Map Chart -->
            <div class="col-md-4">
                <a href="/chart/map" class="text-decoration-none">
                    <div class="card chart-card shadow-sm h-100">
                        <div class="card-img-top">
                            <i class="fas fa-border-all"></i>
                        </div>
                        <div class="card-body text-center">
                            <h5 class="card-title fw-bold">Sleep Treemap</h5>
                            <p class="card-text text-muted">
                                Visualize sleep patterns across Hong Kong's 18 districts.
                            </p>
                            <div class="mt-3">
                                <span class="badge bg-primary me-2">Treemap</span>
                                <span class="badge bg-success">Hierarchical</span>
                            </div>
                            <button class="btn btn-outline-primary mt-3 px-4">
                                View Chart <i class="fas fa-arrow-right ms-2"></i>
                            </button>
                        </div>
                    </div>
                </a>
            </div>
        </div>

        <!-- Quick Stats Preview -->
        <div class="row mt-5">
            <div class="col-12">
                <div class="card bg-light border-0">
                    <div class="card-body p-4">
                        <h4 class="text-center mb-4">
                            <i class="fas fa-chart-simple me-2 text-primary"></i>
                            Quick Insights
                        </h4>
                        <div class="row text-center">
                            <div class="col-md-4 mb-3 mb-md-0">
                                <div class="p-3">
                                    <i class="fas fa-dumbbell fa-2x text-primary mb-2"></i>
                                    <h5>Most Active Age</h5>
                                    <p class="h3">
                                        <%= db.mostActiveAge %>
                                    </p>
                                    <small class="text-muted">Highest exercise frequency</small>
                                </div>
                            </div>
                            <div class="col-md-4 mb-3 mb-md-0">
                                <div class="p-3">
                                    <i class="fas fa-utensils fa-2x text-success mb-2"></i>
                                    <h5>Top Diet</h5>
                                    <p class="h3">
                                        <%= config.DIET_TYPES[db.topDiet] || db.topDiet %>
                                    </p>
                                    <small class="text-muted">
                                        <%= db.topDietPercentage %>% of participants
                                    </small>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="p-3">
                                    <i class="fas fa-moon fa-2x text-info mb-2"></i>
                                    <h5>Best Sleep</h5>
                                    <p class="h3">
                                        <%= db.mostCommonSleep %>
                                    </p>
                                    <small class="text-muted">Most common sleep duration</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Return to Survey Link -->
        <div class="text-center mt-5">
            <a href="/" class="btn btn-outline-secondary btn-lg px-5">
                <i class="fas fa-undo me-2"></i>
                Take Another Survey
            </a>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-light py-4 mt-5">
        <div class="container text-center">
            <p class="text-muted mb-0">
                <i class="fas fa-heart text-danger me-2"></i>
                Thank you for contributing to health research!
            </p>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>